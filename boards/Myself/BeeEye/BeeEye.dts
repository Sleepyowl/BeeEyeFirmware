/dts-v1/;
#include <nordic/nrf52811_qfaa.dtsi>
#include "BeeEye-pinctrl.dtsi"

/ {
	model = "BeeEye-v0.2 Board";
	compatible = "Myself,BeeEye";

	chosen {
		zephyr,console = &uart0;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};

	leds {
		compatible = "gpio-leds";

		status_led: led_0 {
			gpios = <&gpio0 27 GPIO_ACTIVE_HIGH>;
			label = "Status LED";
		};
	};

	buttons {
		compatible = "gpio-keys";

		pair_button: button_0 {
			gpios = <&gpio0 8 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Pair button";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

    vsense {
        compatible = "custom,vsense";
        enable-gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
        io-channels = <&adc 0>; /* example channel index */
        label = "VSENSE";
    };

    ow0: w1 {
        compatible = "zephyr,w1-gpio";
        gpios = <&gpio0 19 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN | GPIO_PULL_UP)>;
        label = "ONEWIRE_0";
    };
};

&uicr {
    // configures P0.21 as reset
	gpio-as-nreset;
};

&adc {
    status = "okay";
};

&clock {
	status = "okay";
	lfclk {
		source = "LFRC";
		cal-enabled = <1>;
	};
};

&reg {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&gpiote {
	status = "okay";
};


&gpio0 {
    status = "okay";
};

&pinctrl {
    /* I2C0 */
    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 0, 0)>,
                    <NRF_PSEL(TWIM_SDA, 0, 30)>;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 0, 0)>,
                    <NRF_PSEL(TWIM_SDA, 0, 30)>;
            low-power-enable;
        };
    };

    /* SPI0 */
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 9)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 7)>,
                    <NRF_PSEL(SPIM_MISO, 0, 5)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 9)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 7)>,
                    <NRF_PSEL(SPIM_MISO, 0, 5)>;
            low-power-enable;
        };
    };

    /* UART0 */
    uart0_default: uart0_default {
        group1 {
            psels = <NRF_PSEL(UART_TX, 0, 26)>,
                    <NRF_PSEL(UART_RX, 0, 28)>;
        };
    };

    uart0_sleep: uart0_sleep {
        group1 {
            psels = <NRF_PSEL(UART_TX, 0, 26)>,
                    <NRF_PSEL(UART_RX, 0, 28)>;
            low-power-enable;
        };
    };
};

&i2c0 {
    compatible = "nordic,nrf-twim";
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
    status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;

	/* RV-3028-C7 real-time clock */
    rv3028: rv3028@52 {
		status = "okay";
        compatible = "microcrystal,rv3028";
        reg = <0x52>;
        int-gpios = <&gpio0 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
        label = "RV3028";
		backup-switch-mode = "level";
		trickle-resistor-ohms = <15000>;
		// zephyr,deferred-init;
    };
};

&spi0 {
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 13 GPIO_ACTIVE_LOW>;
    status = "okay";
    sx1262: sx1262@0 {
        compatible = "semtech,sx1262";
        reg = <0>;
        status = "okay";
        spi-max-frequency = <8000000>;

        reset-gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
        busy-gpios  = <&gpio0 17 GPIO_ACTIVE_HIGH>;
        dio1-gpios  = <&gpio0 15 GPIO_ACTIVE_HIGH>;
        rx-enable-gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
        dio2-tx-enable;
        /*
            Acceptable TXCO voltage constants:
            #define SX126X_DIO3_TCXO_1V6	0x00
            #define SX126X_DIO3_TCXO_1V7	0x01
            #define SX126X_DIO3_TCXO_1V8	0x02
            #define SX126X_DIO3_TCXO_2V2	0x03
            #define SX126X_DIO3_TCXO_2V4	0x04
            #define SX126X_DIO3_TCXO_2V7	0x05
            #define SX126X_DIO3_TCXO_3V0	0x06
            #define SX126X_DIO3_TCXO_3V3	0x07
         */
        dio3-tcxo-voltage = <2>; 
        tcxo-power-startup-delay-ms = <500>;
        label = "SX1262";
    };
};

&uart0 {
    compatible = "nordic,nrf-uarte";
    pinctrl-0 = <&uart0_default>;
    pinctrl-1 = <&uart0_sleep>;
    pinctrl-names = "default", "sleep";
    status = "okay";
	current-speed = <115200>;
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(48)>;
		};

		slot0_partition: partition@c000 {
			label = "image-0";
			reg = <0x0000c000 DT_SIZE_K(56)>;
		};

		slot1_partition: partition@1a000 {
			label = "image-1";
			reg = <0x0001a000 DT_SIZE_K(56)>;
		};

		storage_partition: partition@28000 {
			label = "storage";
			reg = <0x00028000 DT_SIZE_K(32)>;
		};
	};
};